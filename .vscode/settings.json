{
  "breadcrumbs.enabled": true,
  "css.validate": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.tabSize": 2,
  "editor.autoIndent": "full",
  "editor.insertSpaces": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": false,
  "editor.renderWhitespace": "boundary",
  "editor.wordWrapColumn": 80,
  "editor.wordWrap": "off",
  "editor.detectIndentation": true,
  "editor.rulers": [80],
  "files.associations": {
    "*.inc": "php",
    "*.module": "php",
    "*.install": "php",
    "*.theme": "php",
    "*.profile": "php",
    "*.tpl.php": "php",
    "*.test": "php",
    "*.php": "php",
    "*.info": "ini"
  },
  "files.trimTrailingWhitespace": true,
  "files.restoreUndoStack": false,
  "files.insertFinalNewline": true,
  "html.format.enable": true,
  "html.format.wrapLineLength": 80,
  "telemetry.telemetryLevel": "off",
  // End of

  "intelephense.environment.includePaths": ["web/core/includes"],
  "intelephense.files.associations": [
    "*.php",
    "*.phtml",
    "*.inc",
    "*.theme",
    "*.install",
    "*.module",
    "*.profile"
  ],
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.colorTheme": "Andromeda Colorizer",
  "git.autofetch": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.singleQuote": true,
  "editor.fontSize": 14,
  "editor.linkedEditing": true,
  "redhat.telemetry.enabled": false,
  "git.confirmSync": false,
  "explorer.confirmDelete": false,
  "diffEditor.maxComputationTime": 0,
  "editor.multiCursorModifier": "ctrlCmd",
  "[twig]": {
    "editor.defaultFormatter": "mblode.twig-language-2"
  },
  "json.maxItemsComputed": 100000,
  "git.enableSmartCommit": true,
  "security.workspace.trust.untrustedFiles": "open",
  "git.pullTags": false,
  "json.schemas": [],
  "githubPullRequests.pullBranch": "never",
  "debug.javascript.autoAttachFilter": "disabled",
  "git.openRepositoryInParentFolders": "never",
  "prettier.semi": false,
  "prettier.useEditorConfig": false,
  "yaml.customTags": [],
  "files.autoSave": "afterDelay",
  "phpcbf.enable": true,

  // PHP Sniffer & Beautifier
  "phpsab.snifferEnable": true,
  "phpsab.standard": "Drupal,DrupalPractice",
  "phpsab.snifferArguments": [
    "--extensions=inc,theme,install,module,profile,php,phtml,test"
  ],
  "phpsab.fixerEnable": true,
  "phpsab.fixerArguments": [
    "--extensions=inc,theme,install,module,profile,php,phtml,test"
  ],
  "[php]": {
    "editor.defaultFormatter": "valeryanm.vscode-phpsab"
  },
  "phpsab.executablePathCBF": "/home/user/.composer/vendor/bin/phpcs",
  "phpcbf.executablePath": "/home/user/.composer/vendor/bin/phpcbf",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "twig-language-2.braceLine": true,
  "twig-language-2.bracePadding": true,
  "twig-language-2.braces": true,
  "twig-language-2.correct": true,
  "twig-language-2.elseLine": true,
  "twig-language-2.spaceClose": true,
  "twig-language-2.tagSort": true,
  "twig-language-2.comments": true,
  "database-client.autoSync": true,
  "phpcbf.standard": "Drupal,DrupalPractice"
}
